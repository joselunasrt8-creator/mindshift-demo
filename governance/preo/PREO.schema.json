{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://mindshift.local/governance/preo/PREO.schema.json",
    "title": "PREO",
    "description": "Strict schema for a non-operative Pull Request Review Evidence Object.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "pull_request_id",
        "repository",
        "branch",
        "base_branch",
        "commit_sha",
        "changed_files",
        "author_identity",
        "reviewer_identities",
        "approval_state",
        "review_state",
        "status_checks",
        "workflow_results",
        "validation_result",
        "merge_eligibility",
        "validated_at"
    ],
    "properties": {
        "pull_request_id": {
            "type": "integer",
            "minimum": 1
        },
        "repository": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
            "minLength": 3
        },
        "branch": {
            "type": "string",
            "minLength": 1
        },
        "base_branch": {
            "type": "string",
            "minLength": 1
        },
        "commit_sha": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{40}$"
        },
        "changed_files": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "path",
                    "status",
                    "additions",
                    "deletions"
                ],
                "properties": {
                    "path": {
                        "type": "string",
                        "minLength": 1
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "added",
                            "modified",
                            "removed",
                            "renamed"
                        ]
                    },
                    "additions": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "deletions": {
                        "type": "integer",
                        "minimum": 0
                    }
                }
            }
        },
        "author_identity": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "login",
                "id",
                "type"
            ],
            "properties": {
                "login": {
                    "type": "string",
                    "minLength": 1
                },
                "id": {
                    "type": "integer",
                    "minimum": 1
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "User",
                        "Bot",
                        "Organization"
                    ]
                }
            }
        },
        "reviewer_identities": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "login",
                    "id",
                    "type"
                ],
                "properties": {
                    "login": {
                        "type": "string",
                        "minLength": 1
                    },
                    "id": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "User",
                            "Bot",
                            "Organization"
                        ]
                    }
                }
            }
        },
        "approval_state": {
            "type": "string",
            "enum": [
                "PENDING",
                "APPROVED",
                "CHANGES_REQUESTED",
                "DISMISSED",
                "NULL"
            ]
        },
        "review_state": {
            "type": "string",
            "enum": [
                "PENDING_REVIEW",
                "REVIEWED",
                "STALE",
                "BLOCKED",
                "NULL"
            ]
        },
        "status_checks": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "name",
                    "state",
                    "conclusion"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "state": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "SUCCESS",
                            "FAILURE",
                            "ERROR",
                            "CANCELLED",
                            "SKIPPED",
                            "NULL"
                        ]
                    },
                    "conclusion": {
                        "type": "string",
                        "enum": [
                            "PENDING",
                            "PASS",
                            "FAIL",
                            "NEUTRAL",
                            "NULL"
                        ]
                    }
                }
            }
        },
        "workflow_results": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "workflow_name",
                    "run_id",
                    "status",
                    "conclusion"
                ],
                "properties": {
                    "workflow_name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "run_id": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "QUEUED",
                            "IN_PROGRESS",
                            "COMPLETED",
                            "NULL"
                        ]
                    },
                    "conclusion": {
                        "type": "string",
                        "enum": [
                            "SUCCESS",
                            "FAILURE",
                            "CANCELLED",
                            "SKIPPED",
                            "TIMED_OUT",
                            "ACTION_REQUIRED",
                            "NEUTRAL",
                            "NULL"
                        ]
                    }
                }
            }
        },
        "validation_result": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "result",
                "validator_version",
                "validated_object_hash",
                "errors"
            ],
            "properties": {
                "result": {
                    "type": "string",
                    "enum": [
                        "VALID",
                        "NULL"
                    ]
                },
                "validator_version": {
                    "type": "string",
                    "minLength": 1
                },
                "validated_object_hash": {
                    "type": "string",
                    "pattern": "^sha256:[a-fA-F0-9]{64}$",
                    "description": "The canonical PREO hash as sha256:<hex>. It is computed from canonical_json(PREO object excluding validation_result.validated_object_hash) using RFC 8785 JCS semantics, and MUST NOT participate in canonical PREO hash generation."
                },
                "errors": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                            "code",
                            "message"
                        ],
                        "properties": {
                            "code": {
                                "type": "string",
                                "minLength": 1
                            },
                            "message": {
                                "type": "string",
                                "minLength": 1
                            }
                        }
                    }
                }
            },
            "description": "Validation outcome for the exact PREO evidence object. Canonical PREO hash generation MUST use RFC 8785 JSON Canonicalization Scheme (JCS) semantics over the PREO object excluding validation_result.validated_object_hash, so the hash field does not recursively participate in its own digest."
        },
        "merge_eligibility": {
            "type": "string",
            "enum": [
                "PENDING_REVIEW",
                "ELIGIBLE",
                "BLOCKED",
                "NULL"
            ]
        },
        "validated_at": {
            "type": "string",
            "format": "date-time"
        }
    }
}
