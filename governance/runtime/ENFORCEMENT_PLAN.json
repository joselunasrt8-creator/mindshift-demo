{
  "version": "1.1",
  "purpose": "Canonical enforcement planning map before runtime expansion",
  "planning_loop": [
    "inventory all mutation surfaces",
    "classify risk",
    "identify bypasses",
    "define required objects",
    "define validation rules",
    "define proof obligations",
    "define replay semantics",
    "define drift checks",
    "define observability",
    "define enforcement order"
  ],
  "surfaces": [
    {
      "surface_id": "github_production_deploy",
      "path": ".github/workflows/governed-deploy.yml",
      "mutation_type": "production_deployment",
      "risk_class": "P3",
      "bypass_paths": ["direct_wrangler_deploy", "manual_workflow_dispatch", "alternate_deploy_workflow", "unprotected_branch_deploy"],
      "required_objects": ["Authority", "Continuity", "AEO", "ValidationResult", "ExecutionRecord", "ProofOfTransfer", "RegistryRecord"],
      "validation_rules": ["authority.status == ACTIVE", "continuity.status == ACTIVE", "validated_object_hash matches canonical_aeo", "invocation_nonce unused", "repo matches authority constraints", "branch matches authority constraints", "workflow matches authority constraints"],
      "proof_obligations": ["run_id", "commit_sha", "workflow", "environment", "validated_object_hash", "execution_result"],
      "replay_semantics": ["same decision_id + validated_object_hash + invocation_nonce cannot execute twice", "authority is consumed after valid execution", "duplicate validated_object_hash is blocked when authority is single-use"],
      "drift_checks": ["commit_sha cannot change after validation", "workflow cannot change after validation", "branch cannot change after validation", "repo cannot change after validation"],
      "observability_events": ["VALIDATION_GRANTED", "EXECUTION_STARTED", "EXECUTION_COMPLETED", "PROOF_PERSISTED", "REPLAY_BLOCKED", "HASH_MISMATCH"],
      "enforcement_order": 1
    },
    {
      "surface_id": "prepare_governed_deploy",
      "path": ".github/workflows/prepare-governed-deploy.yml",
      "mutation_type": "authority_preparation",
      "risk_class": "P2",
      "bypass_paths": ["manual_prepare_invocation_without_valid_identity", "stale_session_reuse", "continuity_id_mismatch", "authority_created_without_continuity", "compile_output_used_after_expiry"],
      "required_objects": ["Session", "Continuity", "Authority", "AEO", "InvocationNonce"],
      "validation_rules": ["workflow_dispatch only", "session.status == SESSION_ACTIVE", "continuity.status == CONTINUITY_ACTIVE", "authority.decision_id matches continuity authority_chain", "authority.continuity_id matches continuity_id", "compile returns validated_object_hash"],
      "proof_obligations": ["step_summary_contains_decision_id", "step_summary_contains_validated_object_hash", "step_summary_contains_invocation_nonce"],
      "replay_semantics": ["generated invocation_nonce must be single-use downstream", "expired authority cannot compile into valid execution"],
      "drift_checks": ["deploy workflow target cannot change after authority creation", "repo cannot change after authority creation", "branch cannot change after authority creation"],
      "observability_events": ["SESSION_CREATED", "CONTINUITY_CREATED", "AUTHORITY_CREATED", "AEO_COMPILED", "VALIDATION_REJECTED"],
      "enforcement_order": 2
    },
    {
      "surface_id": "runtime_execute_route",
      "path": "src/index.ts",
      "mutation_type": "runtime_execution",
      "risk_class": "P3",
      "bypass_paths": ["execute_without_validation", "execute_with_hash_mismatch", "execute_with_reused_nonce", "execute_after_authority_expiry", "execute_without_proof_requirement"],
      "required_objects": ["Authority", "AEO", "ValidationResult", "InvocationRecord", "ExecutionRecord", "ProofOfTransfer"],
      "validation_rules": ["validation.result == VALID", "validated_object_hash matches compiled AEO", "invocation_nonce unused", "authority not expired", "authority not consumed", "proof requirement exists before execution"],
      "proof_obligations": ["execution_id", "decision_id", "validated_object_hash", "invocation_nonce", "surface", "status"],
      "replay_semantics": ["each invocation_nonce can be reserved once", "execution record blocks duplicate decision_id + validated_object_hash", "reused authority returns NULL"],
      "drift_checks": ["validated object cannot mutate before execution", "target surface cannot differ from validated target", "proof surface must match execution surface"],
      "observability_events": ["VALIDATION_GRANTED", "EXECUTION_STARTED", "EXECUTION_COMPLETED", "REPLAY_BLOCKED", "HASH_MISMATCH", "PROOF_PERSISTED"],
      "enforcement_order": 3
    },
    {
      "surface_id": "runtime_authority_session_continuity_routes",
      "path": "src/index.ts",
      "mutation_type": "authority_registry_mutation",
      "risk_class": "P3",
      "bypass_paths": ["authority_created_without_session", "continuity_created_without_active_session", "authority_created_without_active_continuity", "revocation_not_propagated", "expired_session_remains_active"],
      "required_objects": ["Session", "Continuity", "Authority", "RegistryRecord", "TelemetryEvent"],
      "validation_rules": ["session must be ACTIVE", "continuity must be ACTIVE", "authority must bind continuity_id", "authority must bind identity_id", "expiry must be valid", "revocation cascades to dependent authority"],
      "proof_obligations": ["authority_id", "decision_id", "session_id", "continuity_id", "identity_id", "status", "created_at"],
      "replay_semantics": ["same decision_id cannot create duplicate authority", "revoked continuity cannot produce new authority"],
      "drift_checks": ["authority lineage cannot detach from identity", "continuity hash cannot mismatch canonical continuity", "session expiry cannot be ignored"],
      "observability_events": ["SESSION_CREATED", "CONTINUITY_CREATED", "AUTHORITY_CREATED", "VALIDATION_REJECTED"],
      "enforcement_order": 4
    },
    {
      "surface_id": "runtime_proof_route",
      "path": "src/index.ts",
      "mutation_type": "proof_registry_persistence",
      "risk_class": "P3",
      "bypass_paths": ["proof_written_without_execution", "proof_hash_mismatch", "duplicate_proof_for_single_execution", "proof_missing_lineage", "proof_surface_mismatch"],
      "required_objects": ["ExecutionRecord", "ProofOfTransfer", "RegistryRecord", "Continuity", "TelemetryEvent"],
      "validation_rules": ["execution_id exists", "decision_id matches execution", "validated_object_hash matches execution", "proof includes run_id or equivalent receipt", "proof includes commit_sha when deploy surface", "proof lineage matches authority lineage"],
      "proof_obligations": ["proof_id", "execution_id", "decision_id", "validated_object_hash", "surface", "run_id", "commit_sha", "workflow", "environment", "created_at"],
      "replay_semantics": ["one canonical proof per decision_id + validated_object_hash", "duplicate proof archived or rejected"],
      "drift_checks": ["proof cannot reference different workflow than execution", "proof cannot reference different commit than execution", "proof cannot persist without registry lineage"],
      "observability_events": ["PROOF_PERSISTED", "HASH_MISMATCH", "VALIDATION_REJECTED"],
      "enforcement_order": 5
    },
    {
      "surface_id": "schema_and_migrations",
      "path": "schema.sql + migrations/*.sql",
      "mutation_type": "database_schema_mutation",
      "risk_class": "P2",
      "bypass_paths": ["manual_d1_migration", "schema_change_without_sco", "migration_without_registry_lineage", "destructive_schema_change_without_proof"],
      "required_objects": ["SCO", "PREO", "MigrationPlan", "ValidationResult", "ProofOfTransfer"],
      "validation_rules": ["schema mutation requires SCO", "migration must be reviewed", "destructive migration requires explicit authority", "registry tables must preserve lineage columns"],
      "proof_obligations": ["migration_id", "migration_file", "target_database", "execution_result", "timestamp"],
      "replay_semantics": ["migration id cannot apply twice", "schema hash must not drift after validation"],
      "drift_checks": ["required registry columns remain present", "unique constraints remain present", "lineage columns remain present"],
      "observability_events": ["SCHEMA_VALIDATED", "MIGRATION_APPLIED", "REGISTRY_DRIFT_DETECTED"],
      "enforcement_order": 6
    },
    {
      "surface_id": "wrangler_configuration",
      "path": "wrangler.toml",
      "mutation_type": "deployment_configuration",
      "risk_class": "P2",
      "bypass_paths": ["worker_route_changed_without_authority", "d1_binding_changed_without_validation", "environment_changed_after_validation", "direct_worker_deploy"],
      "required_objects": ["SCO", "PREO", "DeploymentConfigAEO", "ValidationResult"],
      "validation_rules": ["worker name must match governed target", "D1 binding must match authority constraints", "environment must match deployment AEO", "config hash must be stable before deploy"],
      "proof_obligations": ["config_hash", "worker_name", "database_binding", "environment", "commit_sha"],
      "replay_semantics": ["same config hash may not be silently replaced by different target", "config mutation requires new SCO"],
      "drift_checks": ["worker name drift", "D1 database binding drift", "route/environment drift"],
      "observability_events": ["CONFIG_VALIDATED", "CONFIG_DRIFT_DETECTED", "VALIDATION_REJECTED"],
      "enforcement_order": 7
    },
    {
      "surface_id": "package_scripts",
      "path": "package.json",
      "mutation_type": "local_script_execution_surface",
      "risk_class": "P2",
      "bypass_paths": ["npm_script_direct_deploy", "npm_script_direct_migration", "test_script_mutates_registry", "script_invokes_wrangler_without_boundary"],
      "required_objects": ["ScriptInventory", "SCO", "PREO", "ValidationResult"],
      "validation_rules": ["scripts that mutate external state must be classified", "deploy scripts must call governed path only", "migration scripts must require SCO", "test scripts must be non-production or sandboxed"],
      "proof_obligations": ["script_name", "script_hash", "execution_context", "result"],
      "replay_semantics": ["state-changing script invocation requires nonce", "script mutation requires new governance review"],
      "drift_checks": ["script command changed after governance classification", "new script added without surface classification"],
      "observability_events": ["SCRIPT_SURFACE_DETECTED", "SCRIPT_DRIFT_DETECTED", "VALIDATION_REJECTED"],
      "enforcement_order": 8
    },
    {
      "surface_id": "legacy_root_runtime_files",
      "path": "worker.js + registry.js",
      "mutation_type": "legacy_runtime_or_registry_surface",
      "risk_class": "P2",
      "bypass_paths": ["legacy_worker_used_as_alternate_runtime", "registry_write_outside_canonical_runtime", "untracked_legacy_route", "legacy_file_deployed_directly"],
      "required_objects": ["SurfaceClassification", "SCO", "PREO", "ValidationResult"],
      "validation_rules": ["legacy files must be classified active or inert", "active legacy surfaces must route through canonical boundary", "inert legacy files must not be deploy targets"],
      "proof_obligations": ["classification_record", "active_or_inert_status", "deployment_target_status"],
      "replay_semantics": ["legacy runtime cannot execute independently of canonical boundary", "legacy registry writes require governed object"],
      "drift_checks": ["legacy file becomes deploy target", "legacy route added without classification", "registry write added outside proof path"],
      "observability_events": ["LEGACY_SURFACE_DETECTED", "BYPASS_PATH_DETECTED", "VALIDATION_REJECTED"],
      "enforcement_order": 9
    },
    {
      "surface_id": "github_pr_merge_surface",
      "path": "GitHub pull requests / branch protection",
      "mutation_type": "source_control_state_change",
      "risk_class": "P3",
      "bypass_paths": ["direct_push_to_main", "merge_without_PREO", "admin_bypass", "force_push", "branch_protection_disabled"],
      "required_objects": ["PREO", "SCO_if_system_change", "ReviewEvidence", "ValidationResult", "MergeProof"],
      "validation_rules": ["protected branch required", "PREO required before merge", "SCO required for governance/runtime mutation", "checks must pass", "merge actor must be authorized"],
      "proof_obligations": ["pr_number", "merge_commit_sha", "review_status", "checks_status", "merged_by", "timestamp"],
      "replay_semantics": ["same PREO cannot authorize unrelated PR", "closed PR cannot be reused as authority"],
      "drift_checks": ["branch protection drift", "required checks drift", "review rule drift", "admin bypass detected"],
      "observability_events": ["PREO_VALIDATED", "MERGE_PROOF_PERSISTED", "BRANCH_PROTECTION_DRIFT"],
      "enforcement_order": 10
    }
  ]
}
