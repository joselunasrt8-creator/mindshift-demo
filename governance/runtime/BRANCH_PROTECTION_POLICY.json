{
  "version": "1.1",
  "purpose": "Define required repository branch protection controls before Stage 4 enforcement activation.",
  "status": "required_enforcement_policy",
  "target_branch": "main",
  "core_invariant": "No passing governance boundary -> no merge legitimacy",
  "required_controls": {
    "require_pull_request_before_merge": true,
    "require_approvals": true,
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true,
    "require_status_checks": true,
    "required_status_checks": [
      "PREO_VALID",
      "FATE",
      "PREO validation",
      "SCO validation",
      "governed merge validation",
      "deploy proof validation",
      "merge-governance-check",
      "preo-candidate",
      "sco-candidate"
    ],
    "require_branch_up_to_date_before_merge": true,
    "restrict_direct_push_to_main": true,
    "allow_force_pushes": false,
    "allow_branch_deletion": false,
    "require_conversation_resolution": true,
    "block_direct_push": true,
    "require_linear_history": true,
    "restrict_admin_bypass": true
  },
  "admin_bypass_policy": {
    "allow_admin_bypass": false,
    "rationale": "Admin bypass creates alternate mutation paths outside governance visibility.",
    "future_exception_process": "Requires explicit governance policy artifact and audit logging."
  },
  "merge_legitimacy_requirements": [
    "PREO_VALID branch protection check passing",
    "validated PREO generated for exact head_sha",
    "validated SCO generated when governed paths changed",
    "governed merge validation passing",
    "required status checks passing",
    "deploy proof validation passing before deploy eligibility",
    "branch synchronized with main"
  ],
  "forbidden_paths": [
    "direct push to main",
    "force push to main",
    "merge without required checks",
    "admin bypass",
    "governed mutation without SCO visibility",
    "merge legitimacy without PREO visibility"
  ],
  "enforcement_classification": {
    "current": "advisory",
    "target": "branch_protected_enforcement"
  }
}
