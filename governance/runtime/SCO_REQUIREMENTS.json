{
  "version": "1.1",
  "purpose": "Define System Change Object requirements for governance/runtime mutation.",
  "object": "SCO",
  "required_fields": [
    "sco_id",
    "mutation_type",
    "surface",
    "risk_class",
    "changed_files",
    "governed_files",
    "required_review_tier",
    "policy_impact",
    "runtime_impact",
    "proof_requirement",
    "rollback_requirement",
    "head_sha",
    "created_at"
  ],
  "rules": [
    "governance/runtime mutation requires SCO",
    "workflow mutation requires SCO",
    "schema mutation requires SCO",
    "deployment-boundary mutation requires SCO",
    "execution boundary mutation requires P3 highest governance threshold",
    "SCO must bind exact changed files",
    "SCO cannot authorize files outside declared scope",
    "unclassified mutation == NULL"
  ],
  "governed_paths": [
    "src/**",
    "schemas/**",
    "migrations/**",
    ".github/workflows/**",
    "runtime/**",
    "governance/**",
    "schema.sql",
    "wrangler.toml"
  ],
  "status": "enforcing_candidate",
  "target_invariant": "unclassified mutation == NULL",
  "critical_rule": "P3 requires highest governance threshold",
  "mutation_classes": {
    "P0": "documentation",
    "P1": "low-risk runtime",
    "P2": "validator/policy",
    "P3": "execution boundary mutation"
  }
}
