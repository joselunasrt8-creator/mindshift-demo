{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/schemas/dsse_skill_provenance_schema_v1.json",
  "title": "DSSE_SKILL_PROVENANCE_SCHEMA_V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "payload_type", "payload_hash", "signatures"],
  "properties": {
    "schema_version": { "const": "DSSE_SKILL_PROVENANCE_SCHEMA_V1" },
    "payload_type": { "const": "SKILL_METADATA_SCHEMA_V1" },
    "payload_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyid", "sig"],
        "properties": {
          "keyid": { "type": "string", "minLength": 1 },
          "sig": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" }
        }
      }
    }
  }
}
