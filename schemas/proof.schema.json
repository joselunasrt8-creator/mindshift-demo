{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/schemas/mindshift-proof-object.schema.json",
  "title": "MindShift Proof Object",
  "description": "Proof-of-Transfer linked to authority and exact object hash.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_id",
    "execution_id",
    "decision_id",
    "authority_id",
    "aeo_hash",
    "target_system",
    "target_action",
    "result",
    "timestamp",
    "proof_reference",
    "continuity_id",
    "continuity_hash",
    "identity_id",
    "session_id",
    "authority_lineage",
    "execution_lineage"
  ],
  "properties": {
    "proof_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "authority_id": {
      "type": "string",
      "minLength": 1
    },
    "aeo_hash": {
      "type": "string",
      "minLength": 1
    },
    "target_system": {
      "type": "string",
      "minLength": 1
    },
    "target_action": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "blocked"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "proof_reference": {
      "type": "object"
    },
    "continuity_id": {
      "type": "string",
      "minLength": 1
    },
    "continuity_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "identity_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "authority_lineage": {
      "type": "object"
    },
    "execution_lineage": {
      "type": "object"
    },
    "finality_metadata": {
      "type": "object",
      "description": "Optional proof finality metadata. Evidence-only: finality_metadata ≠ authority.",
      "additionalProperties": true,
      "properties": {
        "finality_classification": {
          "type": "string",
          "enum": [
            "LOCAL_VALID",
            "CONVERGENCE_VALID",
            "GLOBAL_VALID",
            "AMBIGUOUS",
            "STALE_VISIBLE",
            "PARTITION_SUSPENDED",
            "NULL"
          ]
        },
        "topology_snapshot_hash": { "type": "string" },
        "epoch_id": { "type": "string" },
        "downgrade_events": { "type": "array" },
        "upgrade_events": { "type": "array" },
        "detached": { "type": "boolean" },
        "detach_reason": { "type": "string" },
        "creates_authority": { "type": "boolean", "const": false },
        "restores_replay": { "type": "boolean", "const": false }
      }
    }
  }
}
