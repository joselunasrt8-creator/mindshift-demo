{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/schemas/mindshift-authority-object.schema.json",
  "title": "MindShift Authority Object",
  "description": "Authority must bind to identity and session continuity before execution can exist.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority_id",
    "decision_id",
    "owner",
    "identity_id",
    "session_id",
    "intent",
    "scope",
    "constraints",
    "expiry",
    "status"
  ],
  "properties": {
    "authority_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "identity_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object"
    },
    "constraints": {
      "type": "object"
    },
    "expiry": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "VALIDATED",
        "RESERVED",
        "CONSUMED",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "signature": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
