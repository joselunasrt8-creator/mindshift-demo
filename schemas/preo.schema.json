{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/schemas/mindshift-preo-object.schema.json",
  "title": "MindShift PREO Object",
  "description": "Pull Request Review Evidence Object.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "preo_id",
    "repo",
    "pr_number",
    "review_state",
    "evidence",
    "created_at"
  ],
  "properties": {
    "preo_id": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "pr_number": {
      "type": [
        "integer",
        "string"
      ]
    },
    "review_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "APPROVED",
        "CHANGES_REQUESTED",
        "REJECTED"
      ]
    },
    "evidence": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
