{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/graph/runtime-topology.schema.json",
  "title": "MindShift Runtime Topology Intelligence v1",
  "type": "object",
  "required": ["generated_at", "repository", "nodes", "edges", "summary"],
  "properties": {
    "generated_at": { "type": "string", "minLength": 1 },
    "repository": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "summary": {
      "type": "object",
      "required": ["node_count", "edge_count", "closure_status_counts"],
      "properties": {
        "node_count": { "type": "integer", "minimum": 0 },
        "edge_count": { "type": "integer", "minimum": 0 },
        "closure_status_counts": {
          "type": "object",
          "required": ["OPEN", "PARTIAL", "CONTAINED", "CLOSED", "BREAK_GLASS"],
          "properties": {
            "OPEN": { "type": "integer", "minimum": 0 },
            "PARTIAL": { "type": "integer", "minimum": 0 },
            "CONTAINED": { "type": "integer", "minimum": 0 },
            "CLOSED": { "type": "integer", "minimum": 0 },
            "BREAK_GLASS": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id","type","label","file_path","symbol","evidence","mutation_capable","authority_bound","continuity_bound","validator_bound","replay_safe","proof_generating","topology_visible","closure_status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["ROUTE","REGISTRY","VALIDATOR","EXECUTION_SURFACE","PROOF_SURFACE","REPLAY_SURFACE","AUTHORITY_SURFACE","CONTINUITY_SURFACE","RECONCILIATION_SURFACE","FINALITY_SURFACE","PARTITION_SURFACE","WORKFLOW_SURFACE","MODULE","TEST","DOC"] },
        "label": { "type": "string" },
        "file_path": { "type": "string" },
        "symbol": { "type": "string" },
        "evidence": { "type": "string" },
        "mutation_capable": { "type": "boolean" },
        "authority_bound": { "type": "boolean" },
        "continuity_bound": { "type": "boolean" },
        "validator_bound": { "type": "boolean" },
        "replay_safe": { "type": "boolean" },
        "proof_generating": { "type": "boolean" },
        "topology_visible": { "type": "boolean" },
        "closure_status": { "enum": ["OPEN","PARTIAL","CONTAINED","CLOSED","BREAK_GLASS"] }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "relation", "evidence", "file_path"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "relation": { "enum": ["CALLS","VALIDATES","WRITES_PROOF","CONSUMES_NONCE","DEPENDS_ON_AUTHORITY","DEPENDS_ON_CONTINUITY","RECONCILES_WITH","CLASSIFIES_FINALITY","MUTATES_STATE","REFERENCES_REGISTRY","REFERENCES_PROOF","REFERENCES_REPLAY","REFERENCES_PARTITION","REFERENCES_WORKFLOW"] },
        "evidence": { "type": "string" },
        "file_path": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
