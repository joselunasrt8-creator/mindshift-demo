{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/graph/runtime-topology.schema.json",
  "title": "MindShift Runtime Topology",
  "type": "object",
  "required": ["generated_at", "nodes", "edges", "summary"],
  "additionalProperties": false,
  "properties": {
    "generated_at": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id","type","label","file_path","symbol","mutation_capable","authority_bound","continuity_bound","validator_bound","replay_safe","proof_generating","topology_visible","closure_status","artifact_role","risk_scope","production_closure_relevant"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "file_path": { "type": "string", "minLength": 1 },
          "symbol": { "type": "string", "minLength": 1 },
          "mutation_capable": { "type": "boolean" },
          "authority_bound": { "type": "boolean" },
          "continuity_bound": { "type": "boolean" },
          "validator_bound": { "type": "boolean" },
          "replay_safe": { "type": "boolean" },
          "proof_generating": { "type": "boolean" },
          "topology_visible": { "type": "boolean" },
          "closure_status": { "type": "string", "enum": ["OPEN", "PARTIAL", "CONTAINED", "CLOSED", "BREAK_GLASS"] },
          "artifact_role": { "type": "string", "enum": ["runtime", "workflow", "script", "migration", "test", "fixture", "doc", "generated", "topology_metadata", "config", "unknown"] },
          "risk_scope": { "type": "string", "enum": ["production_runtime", "governance_runtime", "ci_workflow", "test_only", "documentation_only", "metadata_only", "generated_only", "unknown"] },
          "production_closure_relevant": { "type": "boolean" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "relation", "evidence", "file_path"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "relation": {
            "type": "string",
            "enum": [
              "CALLS","VALIDATES","WRITES_PROOF","CONSUMES_NONCE","DEPENDS_ON_AUTHORITY","DEPENDS_ON_CONTINUITY","RECONCILES_WITH","CLASSIFIES_FINALITY","MUTATES_STATE","REFERENCES_REGISTRY"
            ]
          },
          "evidence": { "type": "string" },
          "file_path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["closure_status_counts_all", "closure_status_counts_production_relevant", "artifact_role_counts", "risk_scope_counts", "mutation_surface_counts_by_role"],
      "additionalProperties": false,
      "properties": {
        "closure_status_counts_all": { "type": "object" },
        "closure_status_counts_production_relevant": { "type": "object" },
        "artifact_role_counts": { "type": "object" },
        "risk_scope_counts": { "type": "object" },
        "mutation_surface_counts_by_role": { "type": "object" }
      }
    }
  }
}
