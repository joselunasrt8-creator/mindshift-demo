{
  "name": "mindshift-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "mindshift": "./cli/index.mjs"
  },
  "scripts": {
    "deploy": "echo \"Direct deploy disabled as a convenience guard. Production deploys must use .github/workflows/governed-deploy.yml.\" && exit 1",
    "deploy:dry-run": "npx wrangler deploy src/index.ts --name mindshift-demo --compatibility-date 2026-05-18 --dry-run",
    "dev": "wrangler dev --local",
    "d1:migrate:local": "wrangler d1 migrations apply mindshift-demo-local --local",
    "test": "node --import tsx --test",
    "test:cli": "node --test tests/cli-sdk-surface.test.mjs",
    "conformance": "node conformance/runner.mjs",
    "graph:load": "npx tsx graph/load_constitutional_graph.ts",
    "graph:runtime": "npx tsx graph/ingest_runtime_graph.ts",
    "graph:governance": "npx tsx graph/ingest_governance_graph.ts",
    "graph:extract": "python3 scripts/extract_repo_graph.py",
    "graph:ingest": "python3 scripts/ingest_neo4j.py",
    "graph:aeo": "npx tsx graph/aeo/ingest_aeo_instances.ts",
    "graph:full": "npm run graph:extract && npm run graph:load && npm run graph:runtime && npm run graph:governance",
    "governance:regenerate": "node scripts/regenerate-governance-artifacts.mjs"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.93.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "dependencies": {
    "neo4j-driver": "^6.0.1"
  },
  "description": "ContinuityOS runtime infrastructure derived from the MindShift canon",
  "keywords": [
    "continuityos",
    "legitimacy",
    "execution-governance",
    "mindshift-canon"
  ]
}
